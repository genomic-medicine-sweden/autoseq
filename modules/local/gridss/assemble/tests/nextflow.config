process {
    withName: 'BWA_INDEX' {
        // GRIDSS requires the BWA index to be prefixed with full name - "genome.fasta"
        ext.prefix = { "genome.fasta" }
    }

    withName: 'UNTAR' {
        // GRIDSS_ASSEMBLE consumes the preprocess working dir by its expected name
        // (`<bam>.gridss.working`), so unpack into a directory with that exact name.
        ext.prefix = { "test.paired_end.markduplicates.gridss.targeted.bam.gridss.working" }
    }
}
