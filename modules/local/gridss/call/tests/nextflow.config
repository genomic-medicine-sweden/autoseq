process {
    withName: 'BWA_INDEX' {
        // GRIDSS requires the BWA index to be prefixed with full name - "genome.fasta"
        ext.prefix = { "genome.fasta" }
    }

    withName: 'UNTAR' {
        // GRIDSS_CALL consumes the preprocess + assemble working dirs by their expected names
        // (`<bam>.gridss.working` / `<assembly_bam>.gridss.working`), so unpack to those exact names.
        ext.prefix = { meta.id == 'gridss_preprocess_dir'
            ? 'test.paired_end.markduplicates.gridss.targeted.bam.gridss.working'
            : 'test_sample.sv.assembly.bam.gridss.working' }
    }
}
